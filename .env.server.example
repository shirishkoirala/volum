# =============================================================================
# Volum environment variables — SERVER DEPLOYMENT
# Copy this file to .env and fill in your values before running.
# WARNING: This configuration exposes the host filesystem. Ensure
# authentication is enabled and a strong session secret is set.
# =============================================================================

# Path to a user home directory to show in "My PC" with a Home icon.
VOLUM_HOME=

# Comma-separated list of extra absolute host paths Volum can browse.
VOLUM_ROOTS=

# Server mode: expose host / and discover mounted drives.
# VOLUM_AUTH_REQUIRED must be true when these are enabled.
VOLUM_INCLUDE_ROOT=true
VOLUM_DISCOVER_ROOTS=true

# Docker server mode maps VOLUM_HOST_PATH to /host inside the container.
VOLUM_HOST_ROOT=/host

# Host directory mounted into Volum. The safe default is ./storage.
# Set this to / only when full host access is explicitly required.
VOLUM_HOST_PATH=./storage

# Bind to localhost by default. Set 0.0.0.0 only for deliberate direct access.
VOLUM_BIND_ADDRESS=127.0.0.1

# Run as an unprivileged host UID/GID with access to the mounted directories.
VOLUM_UID=1000
VOLUM_GID=1000

# Path to the SQLite database file.
VOLUM_DB=/data/volum.db

# HTTP port the server listens on.
VOLUM_PORT=8090

# ---------------------------------------------------------------------------
# Authentication — MUST be enabled for server deployment
# ---------------------------------------------------------------------------

VOLUM_AUTH_REQUIRED=true

# Only set this in isolated local development when VOLUM_AUTH_REQUIRED=false.
VOLUM_ALLOW_INSECURE_AUTH_DISABLED=false

# Long random string used to sign session cookies (minimum 32 bytes).
# Generate one with: openssl rand -base64 32
VOLUM_SESSION_SECRET=

# Optional fixed first-run setup token. If empty, Volum generates one, writes it
# to a 0600 file beside VOLUM_DB, and logs that file path while setup is required.
VOLUM_BOOTSTRAP_TOKEN=

# ---------------------------------------------------------------------------
# Sharing
# ---------------------------------------------------------------------------

# Public base URL for generating share links (e.g. https://volum.example.com).
VOLUM_PUBLIC_URL=

# Comma-separated Host names accepted by the server. Add the LAN address or
# reverse-proxy hostname used to access Volum.
VOLUM_ALLOWED_HOSTS=localhost,127.0.0.1
