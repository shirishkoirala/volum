# =============================================================================
# Volum environment variables
# Copy this file to .env and fill in your values before running.
# =============================================================================

# Comma-separated list of extra absolute host paths Volum can browse.
# Leave empty in server mode if VOLUM_INCLUDE_ROOT/VOLUM_DISCOVER_ROOTS are enabled.
VOLUM_ROOTS=/mnt/storage,/mnt/data1,/mnt/data2,/mnt/backup,/opt/docker

# Server mode: expose host / and discover mounted drives.
VOLUM_INCLUDE_ROOT=false
VOLUM_DISCOVER_ROOTS=false

# Docker server mode maps host / to /host inside the container.
# Leave empty for native/systemd deployment.
VOLUM_HOST_ROOT=

# Path to the SQLite database file.
VOLUM_DB=/data/volum.db

# HTTP port the server listens on.
VOLUM_PORT=8090

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------

# Set true for Linux server deployment.
VOLUM_AUTH_REQUIRED=false

# Password for the admin role (full read/write access).
VOLUM_ADMIN_PASSWORD=change-me

# Optional readonly role (browse, preview, and download only).
VOLUM_READONLY_PASSWORD=

# Long random string used to sign session cookies.
# Required when VOLUM_AUTH_REQUIRED=true.
# Generate one with: openssl rand -base64 32
VOLUM_SESSION_SECRET=replace-with-a-long-random-string

# ---------------------------------------------------------------------------
# Sharing
# ---------------------------------------------------------------------------

# Public base URL for generating share links (e.g. https://volum.example.com).
# Optional; share links will display the token even without this.
VOLUM_PUBLIC_URL=
