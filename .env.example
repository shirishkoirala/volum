# =============================================================================
# Volum environment variables
# Copy this file to .env and fill in your values before running.
# =============================================================================

# Comma-separated list of absolute paths Volum can browse.
# Path traversal and symlink escapes outside these roots are blocked.
VOLUM_ROOTS=/mnt/storage,/mnt/data1,/mnt/data2,/mnt/backup,/opt/docker

# Path to the SQLite database file.
VOLUM_DB=/data/volum.db

# HTTP port the server listens on.
VOLUM_PORT=8090

# ---------------------------------------------------------------------------
# Authentication (optional — leave both passwords empty to disable login)
# ---------------------------------------------------------------------------

# Password for the admin role (full read/write access).
VOLUM_ADMIN_PASSWORD=change-me

# Password for the readonly role (browse, preview, and download only).
VOLUM_READONLY_PASSWORD=view-only

# Long random string used to sign session cookies.
# Required when either password is set.
# Generate one with: openssl rand -base64 32
VOLUM_SESSION_SECRET=replace-with-a-long-random-string
